async function renderCategories() {
    categoriesContainer.innerHTML = '';
    
    // 1. Crear todas las promesas de fetching en paralelo.
    const categoryDataPromises = CATEGORIES.map(async (category) => {
        // Uso de encodeURIComponent para asegurar que los slugs compuestos funcionan (ej. 'ciencia ficcion')
        const endpoint = `/peliculas/categoria/${encodeURIComponent(category.genre)}`;
        // No mostrar el spinner global para cada fetch individual, ya que Promise.all lo gestionará
        const data = await fetchData(endpoint, { showGlobalLoading: false }); 
        return { category, data };
    });

    // 2. Mostrar el spinner global mientras se cargan todas las categorías
    showLoading(); 
    const results = await Promise.all(categoryDataPromises);
    hideLoading(); // Ocultar el spinner global una vez que todos los datos están cargados
    
    // 3. Renderizar resultados en el orden original de CATEGORIES
    results.forEach(({ category, data }) => {
        if (data && data.resultados && data.resultados.length > 0) {
            const { section, row } = createCategoryRow(category);
            
            // Limitar a los primeros 20 resultados para la vista de catálogo
            data.resultados.slice(0, 20).forEach(movie => {
