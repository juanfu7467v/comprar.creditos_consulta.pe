// MODIFICADA la función original para usar el nuevo sistema de chequeo y temporizador
async function handleViewMovieDetails(movie, source){
    showLoading(); // INICIO: Mostrar spinner inmediatamente

    const user = auth.currentUser;
    if (!user) {
        hideLoading(); 
        showErrorModal('Necesitas iniciar sesión para ver contenido. Recarga la página si acabas de iniciar.');
        return;
    }
    
    const creditoCoste = 0; 

    // 1. Chequea si el usuario puede pagar y, si puede, INICIA el temporizador de 20 minutos.
    const sessionStarted = await checkAndStartSession(movie, creditoCoste);
    
    if (!sessionStarted) {
        hideLoading(); // OCULTAR: Si falla la reserva/chequeo
        return; 
    }
    
    // FIX: Cerrar el modal de búsqueda/detalle al abrir el reproductor.
    detailViewModal.classList.remove('active');
    
    let finalUrl = movie.pelicula_url;
    
    // LÓGICA DE CORRECCIÓN DE URL GOOGLE DRIVE Y YOUTUBE
    if (finalUrl && finalUrl.includes('drive.google.com')) {
        const match = finalUrl.match(/\/d\/([^/]+)/);
        if (match) {
            finalUrl = `https://drive.google.com/file/d/${match[1]}/preview`;
            console.log("URL de Drive corregida automáticamente:", finalUrl);
        }
    } 
    
    if (finalUrl && finalUrl.includes('youtube.com/watch?v=')) {
        finalUrl = finalUrl.replace('watch?v=', 'embed/');
        console.log("URL de YouTube corregida automáticamente:", finalUrl);
    }

    if (!finalUrl) {
        hideLoading(); // OCULTAR: Si el enlace está roto
        // ADICIONAL: Si el enlace está roto, cancelamos el timer que acabamos de iniciar
        if (creditDeductionTimer) {
            clearTimeout(creditDeductionTimer);
            creditDeductionTimer = null;
        }
        showErrorModal(`El enlace de reproducción para ${movie.titulo} es nulo o está roto.`);
        return;
    }
    
    const movieWithFixedUrl = {...movie, pelicula_url: finalUrl};
    
    // REGISTRAR EN EL HISTORIAL AL INICIAR LA REPRODUCCIÓN
    await addMovieToHistory(movieWithFixedUrl);
    
    displayMovieDetails(movieWithFixedUrl);

    hideLoading(); // FIN: Ocultar spinner después de que el modal está listo
}

