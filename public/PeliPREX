   LÓGICA DEL CATÁLOGO, BANNER Y FETCHING DE DATOS (REAL)
   ========================================================== */

/**
 * Función genérica para hacer fetch a la API con control de carga.
 * @param {string} endpoint - El endpoint de la API.
 * @param {Object} [options={}] - Opciones adicionales.
 * @param {boolean} [options.showGlobalLoading=true] - Si debe mostrar/ocultar el spinner global.
 */
async function fetchData(endpoint, options = {}) {
    const { showGlobalLoading = true } = options; // Opciones para controlar el spinner global
    
    if (showGlobalLoading) showLoading(); // Mostrar spinner si es necesario

    try {
        const response = await fetch(`${PELIPREX_BASE_URL}${endpoint}`);
        if (!response.ok) {
            throw new Error(`Error HTTP: ${response.status} en ${endpoint}`);
        }
        return await response.json();
    } catch (error) {
        console.error(`Error al cargar datos de ${endpoint}:`, error);
        // MENSAJE DE ERROR QUE EL USUARIO ESTÁ VIENDO
        if (showGlobalLoading) {
             // MODIFICACIÓN: Aviso adecuado sin exponer la API URL
             showErrorModal(`Error de conexión. No se pudieron cargar los datos del catálogo. Por favor, intenta de nuevo.`);
        }
        return null;
    } finally {
        if (showGlobalLoading) hideLoading(); // Ocultar spinner si es necesario
    }
}


