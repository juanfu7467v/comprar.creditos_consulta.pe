// RENOMBRADA Y ADAPTADA la función original para que sea la DEDUCCIÓN FINAL.
// Esta función SÓLO se llama si el temporizador de 20 minutos se completa.
async function finalizeCreditDeduction(amount, movieTitle) {
    const user = auth.currentUser;
    if (!user) {
        console.warn('Deducción final fallida: Necesitas iniciar sesión.');
        return false;
    }
    
    const userRef = db.collection("usuarios").doc(user.uid);
    try {
        await db.runTransaction(async (transaction) => {
            const doc = await transaction.get(userRef);
            
            if (!doc.exists) {
                console.warn("Deducción final fallida: Datos de usuario no encontrados.");
                return false;
            }
            
            const userData = doc.data();
            
            if (userData.tipoPlan === 'ilimitado') {
                return true; 
            }

            if (userData.tipoPlan === 'creditos') {
                const currentCreditos = parseInt(userData.creditos) || 0;
                
                if (currentCreditos < amount) {
                    // Si fallan los créditos en la deducción final (es posible si se gastaron entre 0-20 min)
                    console.warn(`Deducción final fallida: Créditos insuficientes al momento de la deducción. Título: ${movieTitle}`);
                    // Se retorna para que la transacción no falle, pero no se descuenta.
                    return false; 
                }

                const newCreditos = currentCreditos - amount;
                
                transaction.update(userRef, { creditos: newCreditos });
                
                userData.creditos = newCreditos;
                updateProfileUI(userData); 
                
                // NOTIFICACIÓN DE DEDUCCIÓN EXITOSA (ELIMINADA SEGÚN SOLICITUD)
                // showCustomModal('Créditos Descontados', `Se han deducido ${amount} créditos para ver ${movieTitle} (Sesión de 20 minutos completada).`, false);

                return true;
            }
            
            return false; // Otro tipo de plan

        });
        
        return true; 
        
    } catch (error) {
        console.error("Error en la DEDUCCIÓN FINAL (Timer):", error);
        return false; 
    }
}

// NUEVA FUNCIÓN: Chequea créditos antes de iniciar la sesión y, si es OK, activa el temporizador.
async function checkAndStartSession(movie, amount) {
    const user = auth.currentUser;
    if (!user) {
        showErrorModal('Necesitas iniciar sesión para ver contenido.');
        return false;
    }
    
    const userRef = db.collection("usuarios").doc(user.uid);
    try {
        const doc = await userRef.get();
        if (!doc.exists) throw new Error("Datos de usuario no encontrados.");
        const userData = doc.data();

        if (userData.tipoPlan === 'ilimitado') return true;

        if (userData.tipoPlan === 'creditos') {
            const currentCreditos = parseInt(userData.creditos) || 0;
            if (currentCreditos < amount) {
                // Bloquea si no hay créditos
                throw new Error(`CRÉDITOS INSUFICIENTES: Necesitas ${amount} créditos para ver "${movie.titulo}". Solo tienes ${currentCreditos}.`);
            }
            
            // CRÉDITOS SUFICIENTES: Iniciar temporizador para la deducción
            
            // 1. Limpiar cualquier temporizador anterior
            if (creditDeductionTimer) {
                clearTimeout(creditDeductionTimer);
            }

            // 2. Iniciar el nuevo temporizador de 20 minutos.
            creditDeductionTimer = setTimeout(async () => {
                await finalizeCreditDeduction(amount, movie.titulo);
                creditDeductionTimer = null; // Marcar como completado
            }, DEDUCTION_TIME_MS);
            
            console.log(`Sesión iniciada. Créditos se descontarán en ${DEDUCTION_TIME_MS / 60000} minutos si se mantiene la reproducción.`);
            return true; 
        }
        
        throw new Error("Tipo de plan desconocido o no activo.");

    } catch (error) {
        console.error("Error al iniciar la sesión/chequeo de créditos:", error);
        if (error.message.startsWith('CRÉDITOS INSUFICIENTES')) {
            const parts = error.message.split(':');
            showErrorModal(parts[1].trim()); 
        } else {
            showErrorModal(`No se pudo iniciar la sesión. Error: ${error.message}`);
        }
        return false;
    }
}

