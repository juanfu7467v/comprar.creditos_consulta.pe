<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, user-scalable=yes">
  
  <title>Verificación de correo | Masitaprex</title>
  <meta name="description" content="Verifica tu dirección de correo electrónico para activar tu cuenta Masitaprex.">
  
  <link rel="icon" type="image/png" href="https://cdn-icons-png.flaticon.com/128/747/747965.png">
  <link rel="shortcut icon" type="image/png" href="https://cdn-icons-png.flaticon.com/128/747/747965.png">
  <link rel="apple-touch-icon" href="https://cdn-icons-png.flaticon.com/128/747/747965.png">

  <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
  
  <script src="https://www.gstatic.com/firebasejs/10.12.0/firebase-app.js"></script>
  <script src="https://www.gstatic.com/firebasejs/10.12.0/firebase-auth.js"></script>
  
  <style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        -webkit-tap-highlight-color: transparent;
    }

    body {
        font-family: 'Poppins', sans-serif;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: radial-gradient(circle at top right, #fdfbfb 0%, #ebedee 100%);
        padding: 20px;
    }

    #verification-screen {
        width: 100%;
        max-width: 480px;
        padding: 32px 24px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
    }

    /* Mismo fondo que después del registro */
    .verification-container {
        width: 100%;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        animation: fadeIn 0.6s ease-out;
    }

    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }

    /* Ícono de éxito con animación */
    .success-icon-wrapper {
        width: 120px;
        height: 120px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 32px;
        position: relative;
    }

    .success-icon {
        font-size: 120px;
        color: #10b981;
        animation: scaleIn 0.5s cubic-bezier(0.34, 1.56, 0.64, 1), pulse 2s ease-in-out infinite 0.5s;
    }

    @keyframes scaleIn {
        0% { opacity: 0; transform: scale(0); }
        100% { opacity: 1; transform: scale(1); }
    }

    @keyframes pulse {
        0%, 100% { transform: scale(1); }
        50% { transform: scale(1.05); }
    }

    /* Textos */
    h1 {
        font-size: 2rem;
        font-weight: 700;
        margin-bottom: 20px;
        background: linear-gradient(135deg, #0072ff 0%, #00e676 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        letter-spacing: -0.5px;
    }

    .verification-text {
        font-size: 1.1rem;
        line-height: 1.6;
        color: #1a1e2e;
        margin-bottom: 12px;
        max-width: 400px;
        font-weight: 500;
    }

    .instruction-text {
        font-size: 1rem;
        line-height: 1.5;
        color: #64748b;
        margin-bottom: 32px;
        max-width: 400px;
        font-weight: 400;
    }

    .email-highlight {
        background: linear-gradient(135deg, #0072ff15, #00e67615);
        padding: 4px 12px;
        border-radius: 100px;
        font-weight: 600;
        color: #0072ff;
        display: inline-block;
        margin: 8px 0;
        word-break: break-all;
    }

    /* Botón de reenvío */
    .resend-section {
        width: 100%;
        max-width: 360px;
        margin-top: 40px;
    }

    .resend-btn {
        width: 100%;
        height: 58px;
        background: linear-gradient(135deg, #0072ff 0%, #00e676 100%);
        color: white;
        border: none;
        border-radius: 22px;
        font-size: 1.1rem;
        font-weight: 600;
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 12px;
        margin-bottom: 16px;
        box-shadow: 0 12px 24px -6px rgba(0, 114, 255, 0.4);
        transition: all 0.3s ease;
        cursor: pointer;
        font-family: 'Inter', sans-serif;
    }

    .resend-btn:active {
        transform: scale(0.97);
        box-shadow: 0 4px 10px rgba(0, 114, 255, 0.2);
    }

    .resend-btn.disabled {
        opacity: 0.6;
        cursor: not-allowed;
        transform: none;
        box-shadow: 0 4px 12px rgba(0, 114, 255, 0.2);
    }

    /* Timer */
    .timer-text {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        color: #64748b;
        font-size: 0.95rem;
        font-weight: 500;
        margin-bottom: 16px;
    }

    .timer-number {
        background: #f1f5f9;
        padding: 4px 12px;
        border-radius: 100px;
        font-weight: 700;
        color: #0072ff;
        font-family: 'Inter', monospace;
        font-size: 1.1rem;
    }

    /* Link para cambiar correo */
    .change-email-link {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: #0072ff;
        font-weight: 600;
        text-decoration: none;
        padding: 12px 24px;
        border-radius: 100px;
        background: white;
        border: 2px solid #e2e8f0;
        transition: all 0.3s ease;
        margin-top: 16px;
        font-size: 0.95rem;
    }

    .change-email-link:hover {
        background: #f8fafc;
        border-color: #0072ff;
        transform: translateY(-2px);
    }

    .change-email-link:active {
        transform: translateY(0);
    }

    /* Badge de correo enviado */
    .sent-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: #10b98115;
        color: #10b981;
        padding: 8px 20px;
        border-radius: 100px;
        font-size: 0.9rem;
        font-weight: 600;
        margin-bottom: 24px;
    }

    /* Mensajes flotantes */
    #verification-message {
        position: fixed;
        top: 20px;
        left: 50%;
        transform: translateX(-50%) translateY(-100px);
        background: #10b981;
        color: white;
        padding: 16px 28px;
        border-radius: 100px;
        font-weight: 500;
        display: flex;
        align-items: center;
        gap: 12px;
        box-shadow: 0 20px 35px -8px rgba(0, 0, 0, 0.2);
        transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
        z-index: 10000;
        font-size: 0.95rem;
        max-width: 90%;
    }

    #verification-message.show {
        transform: translateX(-50%) translateY(0);
    }

    #verification-message.error {
        background: #ef4444;
    }

    /* Loading overlay */
    #loading-verification {
        position: fixed;
        inset: 0;
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(8px);
        display: none;
        align-items: center;
        justify-content: center;
        z-index: 10001;
    }

    .loading-dots {
        display: flex;
        gap: 8px;
    }

    .dot {
        width: 12px;
        height: 12px;
        border-radius: 50%;
        background: linear-gradient(135deg, #0072ff, #00e676);
        animation: bounce 1.4s infinite ease-in-out both;
    }

    .dot:nth-child(1) { animation-delay: -0.32s; }
    .dot:nth-child(2) { animation-delay: -0.16s; }

    @keyframes bounce {
        0%, 80%, 100% { transform: scale(0); }
        40% { transform: scale(1); }
    }

    @media (max-width: 480px) {
        .verification-container {
            padding: 20px 16px;
        }
        
        h1 {
            font-size: 1.8rem;
        }
        
        .success-icon {
            font-size: 100px;
        }
        
        .success-icon-wrapper {
            width: 100px;
            height: 100px;
            margin-bottom: 24px;
        }
        
        .verification-text {
            font-size: 1rem;
        }
        
        .instruction-text {
            font-size: 0.95rem;
        }
    }
  </style>
</head>
<body>
  <!-- PANTALLA DE VERIFICACIÓN DE CORREO -->
  <div id="verification-screen">
    <div class="verification-container">
      
      <!-- Ícono de éxito animado -->
      <div class="success-icon-wrapper">
        <span class="material-icons success-icon">mark_email_read</span>
      </div>
      
      <!-- Badge de confirmación -->
      <div class="sent-badge">
        <span class="material-icons" style="font-size: 18px;">check_circle</span>
        Correo enviado
      </div>
      
      <!-- Título -->
      <h1>Verifica tu correo</h1>
      
      <!-- Texto de instrucciones (exactamente como se solicitó) -->
      <p class="verification-text">
        Hemos enviado un correo de verificación a tu dirección de correo.
      </p>
      
      <!-- Email del usuario (se actualizará dinámicamente) -->
      <div class="email-highlight" id="user-email-display">
        cargando...
      </div>
      
      <p class="instruction-text">
        Por favor revisa tu bandeja de entrada y abre el enlace para confirmar que el correo te pertenece.<br><br>
        Si te equivocaste de correo, ingresa aquí para cambiarlo.
      </p>
      
      <!-- Link para cambiar correo -->
      <a href="#" class="change-email-link" onclick="handleChangeEmail()">
        <span class="material-icons" style="font-size: 20px;">edit</span>
        Cambiar dirección de correo
      </a>
      
      <!-- Sección de reenvío con temporizador -->
      <div class="resend-section">
        <!-- Timer visual -->
        <div class="timer-text" id="timer-container">
          <span class="material-icons" style="font-size: 20px;">schedule</span>
          <span>Reenviar en</span>
          <span class="timer-number" id="timer-countdown">50</span>
          <span>segundos</span>
        </div>
        
        <!-- Botón de reenvío (deshabilitado inicialmente) -->
        <button class="resend-btn disabled" id="resend-btn" disabled onclick="resendVerificationEmail()">
          <span class="material-icons" style="font-size: 24px;">send</span>
          Reenviar enlace de verificación
        </button>
        
        <p class="instruction-text" style="font-size: 0.85rem; color: #94a3b8; margin-top: 8px;">
          ¿No lo encuentras? Revisa tu bandeja de spam o correos no deseados.
        </p>
      </div>
    </div>
  </div>
  
  <!-- Mensaje flotante para notificaciones -->
  <div id="verification-message"></div>
  
  <!-- Loading overlay -->
  <div id="loading-verification">
    <div class="loading-dots">
      <div class="dot"></div>
      <div class="dot"></div>
      <div class="dot"></div>
    </div>
  </div>

  <script>
    // Configuración de Firebase (misma que en el login)
    const firebaseConfig = {
      apiKey: "AIzaSyC6W5Jw3l5gT4xL0vQ8kN9mZ1qX7rY2sP0",
      authDomain: "masitaprex-4f7d8.firebaseapp.com",
      projectId: "masitaprex-4f7d8",
      storageBucket: "masitaprex-4f7d8.appspot.com",
      messagingSenderId: "1071234567890",
      appId: "1:1071234567890:web:abc123def456ghi789jkl"
    };

    // Inicializar Firebase
    const app = firebase.initializeApp(firebaseConfig);
    const auth = firebase.getAuth(app);
    
    // Variables de estado
    let countdownInterval = null;
    let currentEmail = null;
    let resendAttempts = 0;
    
    // Elementos del DOM
    const verificationScreen = document.getElementById('verification-screen');
    const resendBtn = document.getElementById('resend-btn');
    const timerContainer = document.getElementById('timer-container');
    const timerCountdown = document.getElementById('timer-countdown');
    const userEmailDisplay = document.getElementById('user-email-display');
    const messageEl = document.getElementById('verification-message');
    const loadingEl = document.getElementById('loading-verification');
    
    // Iniciar temporizador de 50 segundos
    function startResendTimer() {
      // Limpiar intervalo existente
      if (countdownInterval) {
        clearInterval(countdownInterval);
      }
      
      let seconds = 50;
      
      // Actualizar UI del timer
      timerCountdown.textContent = seconds;
      timerContainer.style.display = 'flex';
      resendBtn.classList.add('disabled');
      resendBtn.disabled = true;
      
      countdownInterval = setInterval(() => {
        seconds--;
        timerCountdown.textContent = seconds;
        
        if (seconds <= 0) {
          clearInterval(countdownInterval);
          countdownInterval = null;
          timerContainer.style.display = 'none';
          resendBtn.classList.remove('disabled');
          resendBtn.disabled = false;
        }
      }, 1000);
    }
    
    // Mostrar mensaje flotante
    function showMessage(text, isError = false) {
      messageEl.textContent = text;
      messageEl.classList.add('show');
      messageEl.classList.toggle('error', isError);
      
      setTimeout(() => {
        messageEl.classList.remove('show');
      }, 4000);
    }
    
    // Mostrar/ocultar loading
    function showLoading() {
      loadingEl.style.display = 'flex';
    }
    
    function hideLoading() {
      loadingEl.style.display = 'none';
    }
    
    // Verificar estado de verificación del correo
    async function checkEmailVerificationStatus() {
      const user = auth.currentUser;
      if (!user) {
        console.log('No hay usuario autenticado');
        return false;
      }
      
      try {
        await user.reload();
        const isVerified = user.emailVerified;
        
        if (isVerified) {
          // Redirigir al dashboard o pantalla de éxito
          showMessage('¡Correo verificado! Redirigiendo...');
          setTimeout(() => {
            window.location.href = 'actividad';
          }, 2000);
        }
        
        return isVerified;
      } catch (error) {
        console.error('Error al verificar estado:', error);
        return false;
      }
    }
    
    // Enviar correo de verificación
    async function resendVerificationEmail() {
      const user = auth.currentUser;
      
      if (!user) {
        showMessage('Sesión expirada. Por favor, regístrate nuevamente.', true);
        setTimeout(() => {
          window.location.href = 'login.html';
        }, 2000);
        return;
      }
      
      // Limitar intentos de reenvío
      if (resendAttempts >= 5) {
        showMessage('Demasiados intentos. Espera unos minutos.', true);
        return;
      }
      
      showLoading();
      
      try {
        await user.sendEmailVerification({
          url: 'https://masitaprex.com/actividad',
          handleCodeInApp: true
        });
        
        resendAttempts++;
        showMessage('✅ Correo de verificación reenviado');
        startResendTimer(); // Reiniciar timer de 50 segundos
        
      } catch (error) {
        console.error('Error al reenviar correo:', error);
        
        if (error.code === 'auth/too-many-requests') {
          showMessage('Demasiados intentos. Espera 1 minuto.', true);
          startResendTimer(); // Activar timer aunque haya error
        } else {
          showMessage('Error al reenviar. Intenta nuevamente.', true);
        }
      } finally {
        hideLoading();
      }
    }
    
    // Manejar cambio de correo
    function handleChangeEmail() {
      // Volver a la pantalla de registro para cambiar email
      const confirmChange = confirm('¿Quieres cambiar tu dirección de correo? Serás redirigido al registro.');
      
      if (confirmChange) {
        // Cerrar sesión y redirigir al registro
        auth.signOut().then(() => {
          window.location.href = 'login.html?mode=register';
        });
      }
    }
    
    // Verificar periódicamente si el correo ya fue verificado
    function startVerificationChecker() {
      // Verificar inmediatamente
      checkEmailVerificationStatus();
      
      // Luego cada 3 segundos
      setInterval(() => {
        checkEmailVerificationStatus();
      }, 3000);
    }
    
    // Inicializar la pantalla de verificación
    async function initVerificationScreen() {
      showLoading();
      
      try {
        // Esperar a que Firebase Auth esté listo
        await new Promise((resolve) => {
          const unsubscribe = auth.onAuthStateChanged((user) => {
            unsubscribe();
            resolve(user);
          });
        });
        
        const user = auth.currentUser;
        
        if (!user) {
          // No hay usuario autenticado, redirigir al login
          window.location.href = 'login.html';
          return;
        }
        
        // Guardar email actual
        currentEmail = user.email;
        
        // Mostrar email del usuario
        if (userEmailDisplay) {
          userEmailDisplay.textContent = user.email || 'correo registrado';
        }
        
        // Si ya está verificado, redirigir
        await user.reload();
        if (user.emailVerified) {
          window.location.href = 'actividad';
          return;
        }
        
        // Enviar correo de verificación si es la primera vez
        if (!sessionStorage.getItem('verification_sent_' + user.uid)) {
          try {
            await user.sendEmailVerification({
              url: 'https://masitaprex.com/actividad',
              handleCodeInApp: true
            });
            sessionStorage.setItem('verification_sent_' + user.uid, 'true');
            showMessage('📧 Correo de verificación enviado');
          } catch (error) {
            if (error.code !== 'auth/too-many-requests') {
              console.error('Error al enviar verificación:', error);
            }
          }
        }
        
        // Iniciar temporizador de 50 segundos
        startResendTimer();
        
        // Iniciar verificador periódico
        startVerificationChecker();
        
      } catch (error) {
        console.error('Error al inicializar:', error);
        showMessage('Error al cargar. Redirigiendo...', true);
        setTimeout(() => {
          window.location.href = 'login.html';
        }, 2000);
      } finally {
        hideLoading();
      }
    }
    
    // Escuchar cambios en la autenticación
    auth.onAuthStateChanged((user) => {
      if (!user) {
        // Usuario cerró sesión, redirigir al login
        window.location.href = 'login.html';
      }
    });
    
    // Inicializar cuando el DOM esté listo
    document.addEventListener('DOMContentLoaded', () => {
      initVerificationScreen();
    });
    
    // Exponer funciones globalmente
    window.resendVerificationEmail = resendVerificationEmail;
    window.handleChangeEmail = handleChangeEmail;
    
    // Prevenir que el usuario vuelva atrás con el botón del navegador
    window.addEventListener('pageshow', (event) => {
      if (event.persisted) {
        window.location.reload();
      }
    });
  </script>
</body>
</html>
